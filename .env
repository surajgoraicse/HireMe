VITE_MAX_INFINITE_SCROLL_SHORT_SLEEP=2000
VITE_MIN_INFINITE_SCROLL_LONG_SLEEP=1500
VITE_MAX_INFINITE_SCROLL_LONG_SLEEP=4000
VITE_MIN_INFINITE_DECOY_SCROLL_SLEEP=1000
VITE_MAX_INFINITE_DECOY_SCROLL_SLEEP=3000




